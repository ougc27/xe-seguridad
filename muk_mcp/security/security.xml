<?xml version="1.0" encoding="UTF-8"?>

<odoo noupdate="1">

	<record id="rule_mcp_key_user" model="ir.rule">
		<field name="name">MCP Key: own keys</field>
		<field name="model_id" ref="model_muk_mcp_key"/>
		<field name="domain_force">[('user_id', '=', user.id)]</field>
		<field name="groups" eval="[(4, ref('base.group_user'))]"/>
		<field name="perm_read" eval="True"/>
		<field name="perm_write" eval="True"/>
		<field name="perm_create" eval="True"/>
		<field name="perm_unlink" eval="True"/>
	</record>

	<record id="rule_mcp_key_admin" model="ir.rule">
		<field name="name">MCP Key: admin access</field>
		<field name="model_id" ref="model_muk_mcp_key"/>
		<field name="domain_force">[(1, '=', 1)]</field>
		<field name="groups" eval="[(4, ref('base.group_system'))]"/>
		<field name="perm_read" eval="True"/>
		<field name="perm_write" eval="True"/>
		<field name="perm_create" eval="True"/>
		<field name="perm_unlink" eval="True"/>
	</record>

	<record id="rule_mcp_session_user" model="ir.rule">
		<field name="name">MCP Session: own sessions</field>
		<field name="model_id" ref="model_muk_mcp_session"/>
		<field name="domain_force">[('user_id', '=', user.id)]</field>
		<field name="groups" eval="[(4, ref('base.group_user'))]"/>
		<field name="perm_read" eval="True"/>
		<field name="perm_write" eval="True"/>
		<field name="perm_create" eval="True"/>
		<field name="perm_unlink" eval="True"/>
	</record>

	<record id="rule_mcp_session_admin" model="ir.rule">
		<field name="name">MCP Session: admin access</field>
		<field name="model_id" ref="model_muk_mcp_session"/>
		<field name="domain_force">[(1, '=', 1)]</field>
		<field name="groups" eval="[(4, ref('base.group_system'))]"/>
		<field name="perm_read" eval="True"/>
		<field name="perm_write" eval="True"/>
		<field name="perm_create" eval="True"/>
		<field name="perm_unlink" eval="True"/>
	</record>

</odoo>
