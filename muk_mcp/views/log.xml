<?xml version="1.0" encoding="UTF-8"?>

<odoo>

	<record id="view_mcp_log_search" model="ir.ui.view">
		<field name="name">muk_mcp.log.search</field>
		<field name="model">muk_mcp.log</field>
		<field name="arch" type="xml">
			<search>
				<field name="method"/>
				<field name="tool_name"/>
				<field name="model_name"/>
				<field name="user_id"/>
				<filter name="ok" string="OK" domain="[('status', '=', 'ok')]"/>
				<filter name="errors" string="Errors" domain="[('status', '=', 'error')]"/>
				<filter name="denied" string="Denied" domain="[('status', '=', 'denied')]"/>
				<filter name="rate_limited" string="Rate Limited" domain="[('status', '=', 'rate_limited')]"/>
                <group>
					<filter name="group_tool" string="Tool" context="{'group_by': 'tool_name'}"/>
					<filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
					<filter name="group_user" string="User" context="{'group_by': 'user_id'}"/>
				</group>
			</search>
		</field>
	</record>

	<record id="view_mcp_log_tree" model="ir.ui.view">
		<field name="name">muk_mcp.log.tree</field>
		<field name="model">muk_mcp.log</field>
		<field name="arch" type="xml">
			<tree create="false" edit="false">
				<field name="create_date" string="Time"/>
				<field name="key_id"/>
				<field name="user_id"/>
				<field name="method"/>
				<field name="tool_name"/>
				<field name="model_name"/>
				<field name="duration_ms"/>
				<field name="ip_address" optional="hide"/>
				<field
					name="status"
					widget="badge"
					decoration-success="status == 'ok'"
					decoration-danger="status in ('error', 'denied')"
					decoration-warning="status == 'rate_limited'"
				/>
			</tree>
		</field>
	</record>

	<record id="view_mcp_log_graph" model="ir.ui.view">
		<field name="name">muk_mcp.log.graph</field>
		<field name="model">muk_mcp.log</field>
		<field name="arch" type="xml">
			<graph type="line" sample="1">
				<field name="create_date" type="row" interval="day"/>
			</graph>
		</field>
	</record>

	<record id="view_mcp_log_pivot" model="ir.ui.view">
		<field name="name">muk_mcp.log.pivot</field>
		<field name="model">muk_mcp.log</field>
		<field name="arch" type="xml">
			<pivot sample="1">
				<field name="tool_name" type="row"/>
				<field name="create_date" type="col" interval="day"/>
				<field name="status" type="col"/>
			</pivot>
		</field>
	</record>

	<record id="view_mcp_log_form" model="ir.ui.view">
		<field name="name">muk_mcp.log.form</field>
		<field name="model">muk_mcp.log</field>
		<field name="arch" type="xml">
			<form create="false" edit="false">
				<sheet>
					<div class="oe_button_box" name="button_box">
						<button
							name="action_open_record"
							type="object"
							class="oe_stat_button"
							icon="fa-external-link"
							string="Open Record"
							invisible="not model_name or not res_id"
						/>
						<button
							name="action_open_records"
							type="object"
							class="oe_stat_button"
							icon="fa-list"
							string="Open Records"
							invisible="not model_name or not res_ids or res_id"
						/>
					</div>
					<group>
						<group>
							<field name="create_date"/>
							<field name="user_id"/>
							<field name="key_id"/>
							<field name="duration_ms"/>
						</group>
						<group>
							<field name="method"/>
							<field name="tool_name"/>
							<field name="ip_address"/>
							<field
								name="status"
								widget="badge"
								decoration-success="status == 'ok'"
								decoration-danger="status in ('error', 'denied')"
								decoration-warning="status == 'rate_limited'"
							/>
						</group>
					</group>
					<group
                        string="Record Data"
                        invisible="not model_name and not res_id and not res_ids"
                    >
						<group>
							<field name="model_name"/>
						</group>
						<group>
							<field name="res_id" invisible="not res_id"/>
							<field name="res_ids" invisible="res_id or not res_ids"/>
						</group>
					</group>
					<notebook>
						<page string="Request">
							<field name="request_data" widget="code" options="{'mode': 'javascript'}" readonly="1"/>
						</page>
						<page string="Response">
							<field name="response_data" widget="code" options="{'mode': 'javascript'}" readonly="1"/>
						</page>
						<page string="Error" invisible="not error_message">
							<field name="error_message" readonly="1"/>
						</page>
					</notebook>
				</sheet>
			</form>
		</field>
	</record>

	<record id="action_mcp_log" model="ir.actions.act_window">
		<field name="name">Audit Log</field>
		<field name="res_model">muk_mcp.log</field>
		<field name="view_mode">tree,form,graph,pivot</field>
		<field name="context">{'create': False}</field>
	</record>

</odoo>
