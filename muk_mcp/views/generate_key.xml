<?xml version="1.0" encoding="UTF-8"?>

<odoo>

	<record id="view_generate_key_form" model="ir.ui.view">
		<field name="name">muk_mcp.generate_key.form</field>
		<field name="model">muk_mcp.generate_key</field>
		<field name="arch" type="xml">
			<form>
				<group>
					<field name="name" placeholder="e.g. Claude Desktop, Cursor"/>
					<field name="scope"/>
					<field name="rate_limit"/>
				</group>
				<footer>
					<button name="action_make_key" string="Generate Key" type="object" class="btn-primary"/>
					<button string="Cancel" special="cancel"/>
				</footer>
			</form>
		</field>
	</record>

</odoo>
