<?xml version="1.0" encoding="UTF-8"?>

<odoo>

	<record id="view_connect_form" model="ir.ui.view">
		<field name="name">muk_mcp.connect.form</field>
		<field name="model">muk_mcp.connect</field>
		<field name="arch" type="xml">
			<form string="Connect an AI Client">
				<sheet>
					<div class="oe_title">
						<h1>Connect Odoo to your AI</h1>
						<p class="text-muted">
							Pick the AI client you want to use. Local clients
                            (Claude Code, Claude Desktop, Codex CLI, Cursor, OpenCode)
                            connect via a bearer key.
						</p>
					</div>
					<group>
						<field name="mcp_url" readonly="1"/>
						<field name="bearer_key" readonly="1" invisible="not bearer_key"/>
					</group>
					<button
						name="action_generate_key"
						type="object"
						string="Generate Bearer Key"
						class="btn-primary mb-3"
						invisible="bearer_key"
					/>
					<notebook>
						<page string="Claude Code" name="claude_code">
							<field name="claude_code_cmd" widget="text" readonly="1" nolabel="1"/>
						</page>
						<page string="Claude Desktop" name="claude_desktop">
							<field name="claude_desktop_json" widget="text" readonly="1" nolabel="1"/>
						</page>
						<page string="Codex CLI" name="codex">
							<field name="codex_toml" widget="text" readonly="1" nolabel="1"/>
						</page>
						<page string="OpenCode" name="opencode">
							<field name="opencode_json" widget="text" readonly="1" nolabel="1"/>
						</page>
						<page string="Cursor" name="cursor">
							<field name="cursor_json" widget="text" readonly="1" nolabel="1"/>
						</page>
					</notebook>
				</sheet>
				<footer>
					<button special="cancel" string="Close" class="btn-secondary"/>
				</footer>
			</form>
		</field>
	</record>

	<record id="action_connect" model="ir.actions.act_window">
		<field name="name">Connect AI</field>
		<field name="res_model">muk_mcp.connect</field>
		<field name="view_mode">form</field>
		<field name="target">new</field>
	</record>

</odoo>
