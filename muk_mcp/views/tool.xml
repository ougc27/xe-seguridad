<?xml version="1.0" encoding="UTF-8"?>

<odoo>

	<record id="view_mcp_tool_search" model="ir.ui.view">
		<field name="name">muk_mcp.tool.search</field>
		<field name="model">muk_mcp.tool</field>
		<field name="arch" type="xml">
			<search>
				<field name="name"/>
				<field name="description"/>
				<field name="category"/>
				<field name="registry"/>
				<filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <group>
					<filter name="group_category" string="Category" context="{'group_by': 'category'}"/>
					<filter name="group_registry" string="Registry" context="{'group_by': 'registry'}"/>
                </group>
			</search>
		</field>
	</record>

	<record id="view_mcp_tool_tree" model="ir.ui.view">
		<field name="name">muk_mcp.tool.tree</field>
		<field name="model">muk_mcp.tool</field>
		<field name="arch" type="xml">
			<tree>
				<field name="sequence" widget="handle"/>
				<field name="name"/>
				<field name="description"/>
				<field
					name="category"
					widget="badge"
					decoration-success="category == 'read'"
					decoration-warning="category == 'write'"
				/>
				<field
					name="registry"
					widget="badge"
					decoration-muted="not registry"
				/>
				<field name="active" widget="boolean_toggle"/>
			</tree>
		</field>
	</record>

	<record id="view_mcp_tool_form" model="ir.ui.view">
		<field name="name">muk_mcp.tool.form</field>
		<field name="model">muk_mcp.tool</field>
		<field name="arch" type="xml">
			<form>
				<sheet>
					<div class="oe_title">
						<h1>
							<field name="name" placeholder="Tool Name"/>
						</h1>
					</div>
					<group>
						<group>
							<field name="category"/>
							<field name="registry"/>
							<field name="sequence"/>
						</group>
						<group>
							<field name="active" widget="boolean_toggle"/>
						</group>
					</group>
					<notebook>
						<page string="Description" name="description">
							<field 
								name="description"
								placeholder="Describe what this tool does..."
							/>
						</page>
						<page string="Python Code" name="code">
							<field 
								name="code"
								widget="ace"
								options="{'mode': 'python'}"
							/>
						</page>
						<page string="Input Schema" name="schema">
							<field 
								name="input_schema"
								widget="ace"
								options="{'mode': 'javascript'}"
							/>
						</page>
					</notebook>
				</sheet>
			</form>
		</field>
	</record>

	<record id="action_mcp_tool" model="ir.actions.act_window">
		<field name="name">MCP Tools</field>
		<field name="res_model">muk_mcp.tool</field>
		<field name="view_mode">tree,form</field>
		<field name="context">{'search_default_active': 1}</field>
		<field name="help" type="html">
			<p class="o_view_nocontent_smiling_face">
				No MCP tools configured.
			</p>
			<p>
				Tools are automatically created when the module is installed.
				You can add custom tools here.
			</p>
		</field>
	</record>

</odoo>
