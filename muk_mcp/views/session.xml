<?xml version="1.0" encoding="UTF-8"?>

<odoo>

	<record id="view_mcp_session_kanban" model="ir.ui.view">
		<field name="name">muk_mcp.session.kanban</field>
		<field name="model">muk_mcp.session</field>
		<field name="arch" type="xml">
			<kanban create="0" can_open="0">
				<templates>
					<t t-name="kanban-box">
						<div class="oe_kanban_global_click flex-row">
							<div>
								<div>
									<span class="fw-bold fs-5">MCP Session</span>
									<field name="create_date" class="ms-2 text-muted"/>
								</div>
								<small>Last activity: <field name="last_activity"/></small>
							</div>
							<button name="action_revoke" type="object" string="Revoke" class="btn btn-secondary ms-auto my-auto"/>
						</div>
					</t>
				</templates>
			</kanban>
		</field>
	</record>

	<record id="view_mcp_session_tree" model="ir.ui.view">
		<field name="name">muk_mcp.session.tree</field>
		<field name="model">muk_mcp.session</field>
		<field name="arch" type="xml">
			<tree create="false">
				<field name="session_id"/>
				<field name="user_id"/>
				<field name="last_activity"/>
				<field name="create_date"/>
				<field name="active"/>
			</tree>
		</field>
	</record>

	<record id="action_mcp_session" model="ir.actions.act_window">
		<field name="name">Sessions</field>
		<field name="res_model">muk_mcp.session</field>
		<field name="view_mode">tree</field>
		<field name="context">{'active_test': false}</field>
	</record>

</odoo>
