<?xml version="1.0" encoding="UTF-8"?>

<odoo>

	<record id="view_mcp_notification_tree" model="ir.ui.view">
		<field name="name">muk_mcp.notification.tree</field>
		<field name="model">muk_mcp.notification</field>
		<field name="arch" type="xml">
			<tree create="false">
				<field name="event_id"/>
				<field name="session_id"/>
				<field name="method"/>
				<field name="params"/>
				<field name="delivered"/>
				<field name="create_date"/>
			</tree>
		</field>
	</record>

	<record id="action_mcp_notification" model="ir.actions.act_window">
		<field name="name">Notifications</field>
		<field name="res_model">muk_mcp.notification</field>
		<field name="view_mode">tree</field>
	</record>

</odoo>
