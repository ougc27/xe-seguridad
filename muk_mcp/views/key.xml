<?xml version="1.0" encoding="UTF-8"?>

<odoo>

	<record id="view_mcp_key_kanban" model="ir.ui.view">
		<field name="name">muk_mcp.key.kanban</field>
		<field name="model">muk_mcp.key</field>
		<field name="arch" type="xml">
			<kanban create="0" can_open="0">
				<templates>
					<t t-name="kanban-box">
						<div class="oe_kanban_global_click flex-row">
							<div>
								<div>
									<field name="name" class="fw-bold fs-5"/>
									<field name="create_date" class="ms-2 text-muted"/>
								</div>
								<small>Scope: <field name="scope"/></small>
							</div>
							<button name="unlink" type="object" string="Delete" class="btn btn-secondary ms-auto my-auto"/>
						</div>
					</t>
				</templates>
			</kanban>
		</field>
	</record>

	<record id="view_mcp_key_tree" model="ir.ui.view">
		<field name="name">muk_mcp.key.tree</field>
		<field name="model">muk_mcp.key</field>
		<field name="arch" type="xml">
			<tree create="false" edit="false" delete="true">
				<field name="name"/>
				<field name="user_id"/>
				<field name="scope"/>
				<field name="rate_limit"/>
				<field name="last_used"/>
				<field name="active"/>
			</tree>
		</field>
	</record>

	<record id="view_mcp_key_form" model="ir.ui.view">
		<field name="name">muk_mcp.key.form</field>
		<field name="model">muk_mcp.key</field>
		<field name="arch" type="xml">
			<form create="false" edit="false" delete="true">
				<sheet>
					<div class="oe_title">
						<h1>
							<field name="name"/>
						</h1>
					</div>
					<group>
						<group>
							<field name="user_id"/>
							<field name="scope"/>
							<field name="rate_limit"/>
						</group>
						<group>
							<field name="last_used"/>
							<field name="create_date"/>
							<field name="active"/>
						</group>
					</group>
				</sheet>
			</form>
		</field>
	</record>

	<record id="action_mcp_key" model="ir.actions.act_window">
		<field name="name">API Keys</field>
		<field name="res_model">muk_mcp.key</field>
		<field name="view_mode">tree,form</field>
	</record>

</odoo>
