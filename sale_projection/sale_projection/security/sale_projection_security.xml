<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Module category -->
        <record id="module_sale_projection" model="ir.module.category">
            <field name="name">Sale Projection</field>
            <field name="description">Manage weekly sales projections per partner and SKU.</field>
            <field name="sequence">100</field>
        </record>

        <!-- Group: User (can view and edit projections) -->
        <record id="group_sale_projection_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_sale_projection"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Group: Manager (full access + configuration) -->
        <record id="group_sale_projection_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_sale_projection"/>
            <field name="implied_ids" eval="[(4, ref('group_sale_projection_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
