<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         sale.projection — Form View
         ============================================================ -->
    <record id="view_sale_projection_form" model="ir.ui.view">
        <field name="name">sale.projection.form</field>
        <field name="model">sale.projection</field>
        <field name="arch" type="xml">
            <form string="Sale Projection">
                <header>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_done"
                            string="Mark as Done"
                            type="object"
                            invisible="state != 'confirmed'"/>
                    <button name="action_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state == 'draft'"/>
                    <button name="action_generate_lines"
                            string="Generate Lines from SKU Portfolio"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'done'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,confirmed,done"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Partner">
                            <field name="partner_id"
                                   domain="[('is_obra', '=', True)]"
                                   options="{'no_create_edit': True}"/>
                            <field name="constructora_id" readonly="1"/>
                        </group>
                        <group string="Planning Period">
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="line_count" string="Lines" readonly="1"/>
                        </group>
                    </group>

                    <field name="note" placeholder="Internal notes..."/>

                    <!-- Projection lines tab -->
                    <notebook>
                        <page string="Projection Lines" name="lines_tab">
                            <field name="line_ids"
                                   context="{'default_partner_id': partner_id}">
                                <tree editable="bottom"
                                      decoration-success="qty_executed >= qty_projected and qty_projected > 0"
                                      decoration-warning="qty_scheduled > 0 and qty_scheduled &lt; qty_projected"
                                      decoration-muted="qty_projected == 0">
                                    <field name="week_label" readonly="1"/>
                                    <field name="week_start" optional="hide"/>
                                    <field name="product_id"/>
                                    <field name="product_uom_id" optional="hide"/>
                                    <field name="qty_projected"/>
                                    <field name="qty_scheduled" readonly="1"/>
                                    <field name="qty_executed" readonly="1"/>
                                    <field name="unit_price" optional="show"/>
                                    <field name="amount" readonly="1"/>
                                    <field name="currency_id" optional="hide"/>
                                    <button name="action_refresh_quantities"
                                            type="object"
                                            icon="fa-refresh"
                                            title="Refresh quantities from stock"
                                            class="btn-sm btn-secondary"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================
         sale.projection — Tree/List View
         ============================================================ -->
    <record id="view_sale_projection_tree" model="ir.ui.view">
        <field name="name">sale.projection.tree</field>
        <field name="model">sale.projection</field>
        <field name="arch" type="xml">
            <tree string="Sale Projections"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'done'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="constructora_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="line_count" string="Lines"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'done'"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================
         sale.projection — Search View
         ============================================================ -->
    <record id="view_sale_projection_search" model="ir.ui.view">
        <field name="name">sale.projection.search</field>
        <field name="model">sale.projection</field>
        <field name="arch" type="xml">
            <search string="Search Projections">
                <field name="name"/>
                <field name="partner_id" string="Obra"/>
                <field name="constructora_id" string="Construction Company"/>
                <!-- Quick filters -->
                <filter string="Draft" name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="filter_confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter string="Done" name="filter_done"
                        domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="This Month" name="filter_this_month"
                        domain="[('date_from', '&gt;=', (context_today()).strftime('%Y-%m-01'))]"/>
                <!-- Group by -->
                <group expand="0" string="Group By">
                    <filter string="Partner (Obra)" name="group_partner"
                            context="{'group_by': 'partner_id'}"/>
                    <filter string="Construction Company" name="group_constructora"
                            context="{'group_by': 'constructora_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         Action: Sale Projection list
         ============================================================ -->
    <record id="action_sale_projection" model="ir.actions.act_window">
        <field name="name">Projections</field>
        <field name="res_model">sale.projection</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sale_projection_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first projection!
            </p>
            <p>
                Projections let you plan weekly quantities per partner and SKU,
                and automatically track scheduled and executed quantities from inventory movements.
            </p>
        </field>
    </record>

</odoo>
