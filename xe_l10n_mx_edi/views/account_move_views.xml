<odoo>
    <record id="account_move_form_inherit_l10n_mx_edi_skip_sat_update" model="ir.ui.view">
        <field name="name">account.move.form.inherit.l10n.mx.edi.skip.sat.update</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_mx_edi.account_move_form_inherit_l10n_mx_edi"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='l10n_mx_edi_usage']" position="after">
                <field name="skip_sat_update" groups="xe_l10n_mx_edi.group_skip_sat_update"/>
            </xpath>
            <xpath expr="//button[@name='l10n_mx_edi_cfdi_try_sat']" position="attributes">
                <attribute name="groups">account.group_account_manager</attribute>
                <attribute name="confirm">Esta acción consultará el estado en el SAT. ¿Desea continuar?</attribute>
            </xpath>
        </field>
    </record>
</odoo>
