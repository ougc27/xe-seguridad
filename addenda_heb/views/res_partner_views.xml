<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="l10n_mx_edi_inh_res_partner_form_addenda_heb" model="ir.ui.view">
        <field name="name">res.partner.view.form.addenda.heb</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="l10n_mx_edi.l10n_mx_edi_inh_res_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='l10n_mx_edi_addenda']" position="after">
                <field name="addenda_heb_seller_gln" invisible="not l10n_mx_edi_addenda" groups="base.group_system"/>
                <field name="addenda_heb_buyer_gln" invisible=" not l10n_mx_edi_addenda" groups="base.group_system"/>
                <field name="addenda_heb_alternate_party_identification" invisible="not l10n_mx_edi_addenda" groups="base.group_system"/>
            </xpath>
        </field>
    </record>

</odoo>
