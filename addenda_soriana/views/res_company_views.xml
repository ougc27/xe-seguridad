<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_company_form_inherit_social_media" model="ir.ui.view">
        <field name="name">res.company.form.inherit.social.media</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='social_media']" position="after">
                <group string="Addendas" name="addendas" groups="base.group_no_one">
                    <field name="soriana_vendor_number"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
