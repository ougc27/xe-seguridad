<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── List view ─────────────────────────────────────────────────────── -->
    <record id="view_xe_lunch_register_list" model="ir.ui.view">
        <field name="name">xe.lunch.register.list</field>
        <field name="model">xe.lunch.register</field>
        <field name="arch" type="xml">
            <tree string="Meal Service Records">
                <field name="employee_id"/>
                <field name="date"/>
                <field name="timestamp"/>
                <field name="meal_price" sum="Total Cost"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- ── Form view ─────────────────────────────────────────────────────── -->
    <record id="view_xe_lunch_register_form" model="ir.ui.view">
        <field name="name">xe.lunch.register.form</field>
        <field name="model">xe.lunch.register</field>
        <field name="arch" type="xml">
            <form string="Meal Service Record">
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="date"/>
                        <field name="timestamp"/>
                        <field name="meal_price"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_xe_lunch_register_search" model="ir.ui.view">
        <field name="name">xe.lunch.register.search</field>
        <field name="model">xe.lunch.register</field>
        <field name="arch" type="xml">
            <search string="Search Meal Service Records">
                <field name="employee_id"/>
                <field name="date"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <filter string="Today" name="today"
                    domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Date" name="filter_date" date="date"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee"
                        context="{'group_by': 'employee_id'}"/>
                    <filter string="Date" name="group_date"
                        context="{'group_by': 'date'}"/>
                    <filter string="Company" name="group_company"
                        context="{'group_by': 'company_id'}"
                        groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_xe_lunch_register_pivot" model="ir.ui.view">
        <field name="name">xe.lunch.register.pivot</field>
        <field name="model">xe.lunch.register</field>
        <field name="arch" type="xml">
            <pivot string="Meal Service Cost">
                <field name="employee_id" type="row"/>
                <field name="date" interval="week" type="col"/>
                <field name="meal_price" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_xe_lunch_config_form" model="ir.ui.view">
        <field name="name">xe.lunch.config.form</field>
        <field name="model">xe.lunch.config</field>
        <field name="arch" type="xml">
            <form string="Meal Service Configuration">
                <sheet>
                    <group>
                        <field name="meal_price"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_open_lunch_config" model="ir.actions.server">
        <field name="name">Configuration</field>
        <field name="model_id" ref="model_xe_lunch_config"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_settings()</field>
    </record>

    <record id="action_xe_lunch_register" model="ir.actions.act_window">
        <field name="name">Meal Service Records</field>
        <field name="res_model">xe.lunch.register</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="search_view_id" ref="view_xe_lunch_register_search"/>
    </record>

    <record id="action_open_kiosk" model="ir.actions.act_url">
        <field name="name">Open Kiosk</field>
        <field name="url">/lunch/kiosk</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_xe_lunch_kiosk_root"
              name="Meal Service"
              sequence="60"
              web_icon="xe_lunch_kiosk,static/description/icon.png"
              groups="xe_lunch_kiosk.group_xe_lunch_kiosk_user"/>

    <menuitem id="menu_xe_lunch_register"
              name="Meal Service Records"
              parent="menu_xe_lunch_kiosk_root"
              action="action_xe_lunch_register"
              sequence="10"
              groups="xe_lunch_kiosk.group_xe_lunch_kiosk_user"/>

    <menuitem id="menu_xe_lunch_kiosk_open"
              name="Open Kiosk"
              parent="menu_xe_lunch_kiosk_root"
              action="action_open_kiosk"
              sequence="20"
              groups="xe_lunch_kiosk.group_xe_lunch_kiosk_admin"/>

    <menuitem id="menu_xe_lunch_kiosk_config"
              name="Configuration"
              parent="menu_xe_lunch_kiosk_root"
              action="action_open_lunch_config"
              sequence="30"
              groups="xe_lunch_kiosk.group_xe_lunch_kiosk_admin"/>
</odoo>
