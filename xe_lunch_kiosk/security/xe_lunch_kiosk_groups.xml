<odoo>
    <record id="module_category_xe_lunch_kiosk" model="ir.module.category">
        <field name="name">Lunch Kiosk</field>
        <field name="description">XE Lunch Kiosk management</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_xe_lunch_kiosk_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_xe_lunch_kiosk"/>
    </record>

    <record id="group_xe_lunch_kiosk_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_xe_lunch_kiosk"/>
        <field name="implied_ids" eval="[(4, ref('group_xe_lunch_kiosk_user'))]"/>
    </record>
</odoo>
