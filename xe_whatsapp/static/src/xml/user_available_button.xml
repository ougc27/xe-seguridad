<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="xe_whatsapp.user_available_button">
        <t t-if="state.canShowButton">
            <div class="o_user_available_button_systray"
                 t-att-title="tooltip"
                 t-on-click="toggleStatus"
                 style="cursor: pointer;">

                <t t-if="state.online">
                    <i class="fa fa-toggle-on text-success"/>
                </t>
                <t t-else="">
                    <i class="fa fa-toggle-off text-danger"/>
                </t>
            </div>
        </t>
    </t>
</templates>
